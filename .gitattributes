* text=auto eol=lf

# Lockfiles should stay stable in diffs
package-lock.json text eol=lf -diff
pnpm-lock.yaml text eol=lf -diff
yarn.lock text eol=lf -diff

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# Yarn Berry artifacts
/.yarn/releases/** binary
/.yarn/plugins/** binary
