{
  "name": "palm-island",
  "version": "1.0.0",
  "repository": "git@github.com:smourph/palm-island.git",
  "author": "Julien De Conti <julien.de.conti@gmail.com>",
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts eslint.config.mjs --max-warnings=0",
    "lint:fix": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts eslint.config.mjs --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "yarn format:check && yarn lint && yarn typecheck && yarn test:unit && yarn build",
    "test": "yarn test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.13.0"
}
